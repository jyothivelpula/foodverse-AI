# Local defaults — on Render set these in the dashboard (Environment)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/foodverse
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Render notes:
# 1. Create a Render PostgreSQL instance (or skip DB — chat uses built-in persona fallbacks).
# 2. Copy the Internal/External Database URL into DATABASE_URL.
# 3. Set GROQ_API_KEY (required for AI chat).
# 4. Frontend (Vercel): set VITE_API_URL=/api  (NOT the full onrender URL)
#    vercel.json proxies /api → this Render service. Then redeploy frontend.
