# Local defaults — on Render set these in the dashboard (Environment)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/foodverse
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Render notes:
# 1. Dashboard → New → PostgreSQL → Create (same region as the web service).
# 2. Open the Postgres instance → Connections → copy "Internal Database URL"
#    (use Internal if web service + DB are both on Render; else External).
# 3. Web service → Environment → set DATABASE_URL to that URL (paste as-is;
#    postgres:// is auto-normalized). Do NOT use localhost.
# 4. Set GROQ_API_KEY and SECRET_KEY, then Manual Deploy.
# 5. Check https://YOUR-SERVICE.onrender.com/health — "database":"ok" means ready.
#    App auto-creates tables + demo users on boot when DB is reachable.
# 6. Frontend (Vercel): VITE_API_URL=/api (NOT the full onrender URL).
